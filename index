/* == ЗАВАНТАЖЕННЯ ЧАТІВ КОРИСТУВАЧА ==
   Кожен юзер бачить лише свої чати через userChats/{uid}/{chatId}
   Це вирішує проблему з накладанням — створений чат появляється тільки у творця
*/
async function loadMyChats(){
  if(myChatsListener){try{off(ref(db,`userChats/${CU.uid}`),'value',myChatsListener);}catch{}myChatsListener=null;}
  myChatsListener=onValue(ref(db,`userChats/${CU.uid}`),async snap=>{
    if(!snap.exists()){myChats=[];renderChatList(myChats);return;}
    const entries=[];
    // ВИПРАВЛЕНО: додані { } щоб Firebase не зупиняв цикл передчасно
    snap.forEach(c=>{ entries.push({...c.val(), id:c.key}); });
    
    // Отримуємо дані кожного чату
    const chatDataArr=await Promise.all(entries.map(async e=>{
      const cs=await get(ref(db,`chats/${e.id}`));
      if(!cs.exists()) return null;
      // ВИПРАВЛЕНО: id: e.id поставлено в кінці, щоб воно не переписалось
      return{...cs.val(), id:e.id, joinedAt:e.joinedAt||0};
    }));
    myChats=chatDataArr.filter(Boolean);
    // Сортуємо: спочатку global, потім по lastTs
    myChats.sort((a,b)=>{
      if(a.type==='global') return -1;
      if(b.type==='global') return 1;
      return (b.lastTs||b.createdAt||0)-(a.lastTs||a.createdAt||0);
    });
    if(curChatId){const updated=myChats.find(c=>c.id===curChatId);if(updated)curChatData=updated;}
    renderChatList(myChats);
  });
}

/* == РЕНДЕР СПИСКУ ЧАТІВ == */
function renderChatList(chats){
  const el=document.getElementById('cl');
  el.innerHTML='';
  // Дедуплікація
  const seen=new Set();
  const unique=chats.filter(c=>{if(seen.has(c.id))return false;seen.add(c.id);return true;});
  // Фільтр по табу
  const flt=activeChatTab==='all'?unique:unique.filter(c=>{
    if(activeChatTab==='dm') return c.type==='dm';
    if(activeChatTab==='group') return c.type==='group'||c.type==='global';
    if(activeChatTab==='channel') return c.type==='channel';
    return true;
  });
  if(!flt.length){
    el.innerHTML=`<div style="padding:20px;text-align:center;color:var(--txt2);font-size:10px;font-family:var(--ff-mono);line-height:1.8">${activeChatTab==='all'?'Немає чатів.<br>Введіть @юзернейм в пошук<br>щоб знайти людину або групу':'Немає чатів у цій категорії'}</div>`;
    return;
  }
  flt.forEach(ch=>{
    const d=document.createElement('div');
    d.className='ci'+(curChatId===ch.id?' active':'');
    d.dataset.id=ch.id;
    let avClass='ci-av-g',icon='💬',sub='';
    if(ch.type==='dm'){avClass='ci-av-dm';icon=ch.otherEmoji||'👤';sub='👤 Особисте';}
    else if(ch.type==='channel'){avClass='ci-av-c';icon=ch.emoji||'📢';sub='📢 Канал'+(ch.username?` · @${ch.username}`:'');}
    else if(ch.type==='global'){avClass='ci-av-gl';icon='🌍';sub='🌍 Глобальний';}
    else{avClass='ci-av-gr';icon=ch.emoji||'👥';sub='👥 Група'+(ch.username?` · @${ch.username}`:'');}
    const nm=ch.type==='dm'?(ch.otherNickname||ch.otherUsername||'Користувач'):(ch.name||ch.id);
    d.innerHTML=`<div class="ci-av ${avClass}">${icon}</div><div class="ci-inf"><div class="ci-name">${esc(nm)}</div><div class="ci-prev">${sub}</div></div>`;
    d.onclick=()=>{openChat(ch);closeSearchResults();};
    el.appendChild(d);
  });
}


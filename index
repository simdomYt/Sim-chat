              <button class="mact-sm ban-btn" title="Забанити" onclick="banMember('${m.uid}','${esc(m.username||'')}')">🔨</button>
            </div>`:'';
          return`<div class="member-item">
            <div class="ci-av ci-av-gr" style="width:32px;height:32px;font-size:16px;flex-shrink:0">${m.emoji||'👤'}</div>
            <div class="member-item-info">
              <div class="member-item-nm">${esc(m.nickname||m.username||m.uid)}</div>
              <div class="member-item-tg">@${esc(m.username||m.uid)}</div>
            </div>
            ${role}${actBtns}
          </div>`;
        }).join('')}
      `;
      // Заблоковані
      const bannedList=Object.keys(banned);
      if(bannedList.length&&isAdmin){
        membersHtml+=`<div class="ss-title" style="font-size:9px;color:var(--txt2);font-family:var(--ff-mono);text-transform:uppercase;letter-spacing:1px;margin:14px 0 8px">Заблоковані (${bannedList.length})</div>`;
        membersHtml+=bannedList.map(uid=>`<div class="member-item">

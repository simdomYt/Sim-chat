/* == ГОЛОСОВІ/ВІДЕО == */
window.startRec=async(isVideo=false)=>{
  if(mediaRec) return;
  isVidRec=isVideo;
  try{
    const stream=await navigator.mediaDevices.getUserMedia(isVideo?{audio:true,video:{facingMode:'user'}}:{audio:true});
    mediaRec=new MediaRecorder(stream);recChunks=[];
    mediaRec.ondataavailable=e=>recChunks.push(e.data);
    mediaRec.start(100);recSecs=0;
    document.getElementById('rec-lbl').textContent=isVideo?'Відеокружок...':'Голосове...';
    document.getElementById('rec-ui').classList.add('on');
    document.getElementById('iz').style.display='none';
    recTimer=setInterval(()=>{recSecs++;document.getElementById('rec-t').textContent=`${Math.floor(recSecs/60)}:${String(recSecs%60).padStart(2,'0')}`;},1000);
  }catch{toast('Немає доступу до мікрофону');}
};
window.cancelRec=()=>stopRec(false);
window.sendRec=()=>stopRec(true);
function stopRec(doSend){
  if(!mediaRec) return;
  clearInterval(recTimer);
  mediaRec.stream.getTracks().forEach(t=>t.stop());
  if(doSend){
    mediaRec.onstop=async()=>{
      const blob=new Blob(recChunks,{type:isVidRec?'video/webm':'audio/webm'});
      const dur=`${Math.floor(recSecs/60)}:${String(recSecs%60).padStart(2,'0')}`;
      const reader=new FileReader();
      reader.onload=async()=>{
        const payload={uid:CU.uid,nickname:CP.nickname,username:CP.username,emoji:CP.emoji,ts:Date.now()};
        if(isVidRec) payload.videoUrl=reader.result;
        else{payload.voiceUrl=reader.result;payload.dur=dur;}
        await push(ref(db,`messages/${curChatId}`),payload);
        await update(ref(db,`chats/${curChatId}`),{lastMsg:isVidRec?'📹 Відео':'🎤 Голосове',lastTs:Date.now()});
      };
      reader.readAsDataURL(blob);
    };
  }
  mediaRec.stop();mediaRec=null;recChunks=[];
  document.getElementById('rec-ui').classList.remove('on');
  document.getElementById('iz').style.display='';
}
window.playAudio=url=>{new Audio(url).play();};


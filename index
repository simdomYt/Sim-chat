/* == ПОШУК (новий, розширений) ==
   Шукає: людей по юзернейму, групи/канали по @username
   Для людей — відкриває DM
   Для груп/каналів — показує "Приєднатись"
*/
window.handleSearch=q=>{
  clearTimeout(searchDebounce);
  const trimmed=q.trim();
  if(!trimmed){closeSearchResults();renderChatList(myChats);return;}
  // Локальна фільтрація своїх чатів
  const l=trimmed.toLowerCase().replace(/^@/,'');
  const local=myChats.filter(c=>{
    const nm=(c.type==='dm'?c.otherNickname:c.name)||'';
    const un=(c.type==='dm'?c.otherUsername:c.username)||'';
    return nm.toLowerCase().includes(l)||un.toLowerCase().includes(l)||(c.id||'').toLowerCase().includes(l);
  });
  renderChatList(local);
  // Якщо схоже на юзернейм — шукаємо глобально
  searchDebounce=setTimeout(()=>globalSearch(trimmed),400);
};

async function globalSearch(q){
  const clean=q.toLowerCase().replace(/^@/,'').trim();
  if(clean.length<2) return;
  const results=[];
  // Шукаємо юзерів
  try{
    const uSnap=await get(ref(db,`usernames/${clean}`));
    if(uSnap.exists()){
      const uid=uSnap.val();
      if(uid!==CU.uid){
        const us=await get(ref(db,`users/${uid}`));
        const u=us.val()||{};
        results.push({kind:'user',uid,username:clean,nickname:u.nickname||clean,emoji:u.emoji||'👤'});
      }
    }
  }catch{}
  // Шукаємо групи/канали по юзернейму
  try{
    const cSnap=await get(ref(db,'chats'));
    if(cSnap.exists()){
      cSnap.forEach(c=>{
        const d=c.val();
        if(!d.username) return;
        if(d.username.toLowerCase().includes(clean)||(d.name||'').toLowerCase().includes(clean)){
          results.push({kind:'chat',id:c.key,...d});
        }
      });
    }
  }catch{}
  showSearchResults(results,q);
}

function showSearchResults(results,q){
  const box=document.getElementById('search-results');
  if(!results.length){box.innerHTML=`<div style="padding:14px;text-align:center;font-size:10px;color:var(--txt2);font-family:var(--ff-mono)">Нічого не знайдено за "${esc(q)}"</div>`;box.classList.add('show');return;}
  let html='';
  const users=results.filter(r=>r.kind==='user');
  const chats=results.filter(r=>r.kind==='chat');
  if(users.length){
    html+=`<div class="sr-section">Користувачі</div>`;
    users.forEach(u=>{
      const inCts=!!LS.cts()[u.uid];
      html+=`<div class="sr-item" onclick="openDMFromSearch('${u.uid}','${esc(u.username)}','${esc(u.nickname)}','${u.emoji}')">
        <div class="sr-av ci-av-dm">${u.emoji}</div>
        <div class="sr-info"><div class="sr-name">${esc(u.nickname)}</div><div class="sr-sub">@${esc(u.username)}${inCts?' · 📞 Контакт':''}</div></div>
        <div class="sr-action">Написати ></div>
      </div>`;
    });
  }
  if(chats.length){
    html+=`<div class="sr-section">Групи та Канали</div>`;
    chats.forEach(c=>{
      const alreadyIn=myChats.some(mc=>mc.id===c.id);
      html+=`<div class="sr-item" onclick="${alreadyIn?`openChatById('${c.id}')`:`joinChatFromSearch('${c.id}')`}">
        <div class="sr-av ${c.type==='channel'?'ci-av-c':'ci-av-gr'}">${c.emoji||'👤'}</div>
        <div class="sr-info"><div class="sr-name">${esc(c.name||c.id)}</div><div class="sr-sub">${c.type==='channel'?'📢 Канал':'👥 Група'}${c.username?` · @${c.username}`:''}</div></div>
        <div class="sr-action">${alreadyIn?'Відкрити >':'Приєднатись +'}</div>
      </div>`;
    });
  }
  box.innerHTML=html;
  box.classList.add('show');
}


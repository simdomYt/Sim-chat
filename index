/* == E2E ENCRYPTION == */
const E2E={
  async genKeyPair(){const kp=await crypto.subtle.generateKey({name:'ECDH',namedCurve:'P-256'},true,['deriveKey']);return{pub:await crypto.subtle.exportKey('jwk',kp.publicKey),prv:await crypto.subtle.exportKey('jwk',kp.privateKey)};},
  async deriveFromStr(str,salt){const enc=new TextEncoder();const km=await crypto.subtle.importKey('raw',enc.encode(str),{name:'PBKDF2'},false,['deriveKey']);return crypto.subtle.deriveKey({name:'PBKDF2',salt:enc.encode(salt.padEnd(16,'_').slice(0,16)),iterations:100000,hash:'SHA-256'},km,{name:'AES-GCM',length:256},false,['encrypt','decrypt']);},
  async encrypt(text,key){const iv=crypto.getRandomValues(new Uint8Array(12));const ct=await crypto.subtle.encrypt({name:'AES-GCM',iv},key,new TextEncoder().encode(text));const out=new Uint8Array(12+ct.byteLength);out.set(iv);out.set(new Uint8Array(ct),12);return btoa(String.fromCharCode(...out));},
  async decrypt(b64,key){try{const d=Uint8Array.from(atob(b64),c=>c.charCodeAt(0));const pt=await crypto.subtle.decrypt({name:'AES-GCM',iv:d.slice(0,12)},key,d.slice(12));return new TextDecoder().decode(pt);}catch{return'🔒 [зашифровано]';}}
};


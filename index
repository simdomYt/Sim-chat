window.openDMFromSearch=async(otherUid,otherUsername,otherNickname,otherEmoji)=>{
  closeSearchResults();
  // Перевіряємо чи DM вже існує
  const existing=myChats.find(c=>c.type==='dm'&&c.otherUid===otherUid);
  if(existing){openChat(existing);return;}
  // Створюємо новий DM
  const dmId=[CU.uid,otherUid].sort().join('_dm_');
  await set(ref(db,`chats/${dmId}`),{type:'dm',createdAt:Date.now(),members:{[CU.uid]:true,[otherUid]:true}});
  // Додаємо обом у userChats
  await set(ref(db,`userChats/${CU.uid}/${dmId}`),{joinedAt:Date.now(),type:'dm',otherUid,otherUsername,otherNickname,otherEmoji});
  await set(ref(db,`userChats/${otherUid}/${dmId}`),{joinedAt:Date.now(),type:'dm',otherUid:CU.uid,otherUsername:CP.username,otherNickname:CP.nickname,otherEmoji:CP.emoji});
  toast(`✅ Чат з @${otherUsername} відкрито`);
  // loadMyChats оновиться автоматично через listener
};


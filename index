/* == ЗБЕРЕГТИ НАЛАШТУВАННЯ ЧАТУ == */
window.saveChatSettings=async()=>{
  const nm=document.getElementById('cpp-newnm')?.value.trim();
  const un=document.getElementById('cpp-newun')?.value.trim().toLowerCase().replace(/[^a-z0-9_]/g,'');
  if(!nm||!curChatId) return toast('Введіть назву');
  // Перевірка юзернейму
  if(un&&un!==curChatData?.username){
    const snap=await get(ref(db,`chatusernames/${un}`));
    if(snap.exists()&&snap.val()!==curChatId) return toast(`@${un} вже зайнятий`);
    if(curChatData?.username) await remove(ref(db,`chatusernames/${curChatData.username}`));
    await set(ref(db,`chatusernames/${un}`),curChatId);
    await update(ref(db,`chats/${curChatId}`),{username:un});
    curChatData.username=un;
  }
  await update(ref(db,`chats/${curChatId}`),{name:nm});
  curChatData.name=nm;
  document.getElementById('hdr-nm').textContent=nm;
  const i=myChats.findIndex(c=>c.id===curChatId);if(i>=0){myChats[i].name=nm;if(un)myChats[i].username=un;}
  renderChatList(myChats);
  toast('Збережено ✅');
};

window.linkGroup=async()=>{
  const gid=document.getElementById('lnk-sel')?.value||'';
  if(!curChatId) return;
  await update(ref(db,`chats/${curChatId}`),{linkedGroupId:gid||null});
  curChatData.linkedGroupId=gid||null;
  const i=myChats.findIndex(c=>c.id===curChatId);if(i>=0)myChats[i].linkedGroupId=gid||null;
  toast(gid?'Групу прив\'язано ✅':'Прив\'язку видалено');
};

window.deleteChat=async()=>{
  if(!curChatId||curChatData?.creatorUid!==CU?.uid) return;
  const ok=confirm('Видалити чат назавжди?');
  if(!ok) return;
  // Видаляємо з userChats всіх учасників
  const membSnap=await get(ref(db,`chats/${curChatId}/members`));
  if(membSnap.exists()){
    const ps=Object.keys(membSnap.val()||{}).map(uid=>remove(ref(db,`userChats/${uid}/${curChatId}`)));
    await Promise.all(ps);
  }
  await remove(ref(db,`chats/${curChatId}`));
  await remove(ref(db,`messages/${curChatId}`));
  if(curChatData?.username) await remove(ref(db,`chatusernames/${curChatData.username}`));
  myChats=myChats.filter(c=>c.id!==curChatId);
  detach();curChatId=null;curChatData=null;
  document.getElementById('cv').style.display='none';
  document.getElementById('welcome').style.display='flex';
  renderChatList(myChats);
  document.getElementById('cpp').classList.remove('open');
  toast('Видалено');
};

/* == ДОДАТИ УЧАСНИКІВ (тільки контакти) == */
window.openAddMembersModal=async()=>{
  const cts=LS.cts();
  const ctKeys=Object.keys(cts);
  const box=document.getElementById('contacts-to-add');
  if(!ctKeys.length){box.innerHTML=`<div style="text-align:center;font-size:10px;color:var(--txt2);font-family:var(--ff-mono);padding:14px">У вас немає контактів.<br>Додайте їх через пошук.</div>`;openModal('add-members-modal');return;}
  // Отримуємо поточних учасників
  const membSnap=await get(ref(db,`chats/${curChatId}/members`));
  const alreadyIn=new Set(Object.keys(membSnap.val()||{}));
  box.innerHTML='';
  ctKeys.forEach(uid=>{
    const c=cts[uid];
    const inChat=alreadyIn.has(uid);
    const d=document.createElement('div');
    d.className='ct-item';
    d.innerHTML=`<span style="font-size:20px">${c.emoji||'👤'}</span><div class="ct-item-info"><div class="ct-item-nm">${esc(c.nickname||c.username)}</div><div class="ct-item-tg">@${esc(c.username||'')}</div></div>${inChat?`<span style="font-size:10px;color:var(--success);font-family:var(--ff-mono)">✅ В чаті</span>`:`<button class="btn-s" style="width:auto;padding:4px 10px;font-size:10px;margin:0" onclick="addMemberToChat('${uid}','${esc(c.username||'')}')">Додати</button>`}`;
    box.appendChild(d);
  });
  openModal('add-members-modal');
};

window.addMemberToChat=async(uid,username)=>{
  if(!curChatId) return;
  const cs=await get(ref(db,`chats/${curChatId}`));
  const cd=cs.val()||{};
  await set(ref(db,`chats/${curChatId}/members/${uid}`),true);
  await set(ref(db,`userChats/${uid}/${curChatId}`),{joinedAt:Date.now(),type:cd.type||'group'});
  toast(`@${username} додано до чату ✅`);
  openAddMembersModal();
};

/* == ПРОФІЛЬ КОРИСТУВАЧА == */
window.openUserModalByMsg=(uid,username,nickname,emoji)=>{
  const no=LS.no(),cts=LS.cts();
  const custom=no[uid]||'';
  const inCts=!!cts[uid];
  document.getElementById('um-body').innerHTML=`
    <div class="user-profile-av">${emoji}</div>
    <div class="user-profile-nm">${esc(custom||nickname)}</div>
    <div class="user-profile-tg">@${esc(username)}</div>
    <div class="form-group"><label>Власний нікнейм (лише для вас)</label><input class="form-input" id="um-ov" value="${esc(custom)}" placeholder="${esc(nickname)}"></div>
    <button class="btn-s" onclick="saveNO('${uid}')">Зберегти нікнейм</button>
    <div class="user-action-row">
      <button class="btn-s" onclick="${inCts?`rmCt('${uid}')`:`addCtByUid('${uid}','${esc(username)}','${esc(nickname)}','${emoji}')`}">${inCts?'❌ З контактів':'➕ До контактів'}</button>
      <button class="btn-s" onclick="openDMFromSearch('${uid}','${esc(username)}','${esc(nickname)}','${emoji}');closeModal('user-modal')">💬 Написати</button>
    </div>
  `;
  openModal('user-modal');
};

window.saveNO=uid=>{
  const val=document.getElementById('um-ov')?.value.trim();
  const no=LS.no();if(val)no[uid]=val;else delete no[uid];
  LS.saveNo(no);closeModal('user-modal');toast('Нікнейм збережено');
};

/* == КОНТАКТИ == */
window.addCtByUid=(uid,username,nickname,emoji)=>{
  const cts=LS.cts();cts[uid]={username,nickname,emoji};LS.saveCts(cts);renderContacts();toast(`@${username} додано ✅`);closeModal('user-modal');
};
window.rmCt=uid=>{const cts=LS.cts();delete cts[uid];LS.saveCts(cts);renderContacts();closeModal('user-modal');toast('Видалено');};

function renderContacts(){
  const list=document.getElementById('ct-list');if(!list)return;
  const cts=LS.cts(),keys=Object.keys(cts);
  if(!keys.length){list.innerHTML=`<div style="font-size:10px;color:var(--txt2);font-family:var(--ff-mono);padding:6px 0">Немає контактів</div>`;return;}
  list.innerHTML='';
  keys.forEach(uid=>{
    const c=cts[uid];
    const d=document.createElement('div');d.className='ct-item';
    d.innerHTML=`<span style="font-size:17px">${c.emoji||'👤'}</span><div class="ct-item-info"><div class="ct-item-nm">${esc(c.nickname||c.username)}</div><div class="ct-item-tg">@${esc(c.username||'')}</div></div><button class="ct-rm" onclick="rmCt('${uid}')">❌</button>`;
    d.onclick=e=>{if(e.target.classList.contains('ct-rm'))return;openDMFromSearch(uid,c.username,c.nickname,c.emoji||'👤');closeSP();};
    list.appendChild(d);
  });
}

/* Пошук контакту під час набору */
window.searchContactInput=async val=>{
  const clean=val.trim().toLowerCase().replace(/^@/,'');
  const box=document.getElementById('contact-search-res');
  if(!box) return;
  if(!clean){box.innerHTML='';return;}
  try{
    const snap=await get(ref(db,`usernames/${clean}`));
    if(!snap.exists()){box.innerHTML=`<div style="font-size:10px;color:var(--txt2);font-family:var(--ff-mono)">@${esc(clean)} — не знайдено</div>`;return;}
    const uid=snap.val();
    const us=await get(ref(db,`users/${uid}`));
    const u=us.val()||{};
    const inCts=!!LS.cts()[uid];
    box.innerHTML=`<div class="ct-item" style="margin-top:6px">
      <span style="font-size:17px">${u.emoji||'👤'}</span>
      <div class="ct-item-info"><div class="ct-item-nm">${esc(u.nickname||clean)}</div><div class="ct-item-tg">@${esc(clean)}</div></div>
      ${inCts?`<span style="font-size:10px;color:var(--success);font-family:var(--ff-mono)">✅</span>`:
      `<button class="btn-s" style="width:auto;padding:4px 10px;font-size:10px;margin:0" onclick="addCtByUid('${uid}','${esc(clean)}','${esc(u.nickname||clean)}','${u.emoji||'👤'}');document.getElementById('add-ct').value='';document.getElementById('contact-search-res').innerHTML=''">Додати</button>`}
    </div>`;
  }catch{box.innerHTML='';}
};

/* == СТВОРЕННЯ ЧАТУ == */
window.openCreateModal=async()=>{
  buildEmojiGrid('ct-ep',e=>selCreateEmoji=e,selCreateEmoji);
  const sel=document.getElementById('ct-linked');
  sel.innerHTML='<option value="">— без групи —</option>';
  myChats.filter(c=>c.type==='group').forEach(g=>{const o=document.createElement('option');o.value=g.id;o.textContent=g.name||g.id;sel.appendChild(o);});
  document.getElementById('ct-nm').value='';
  document.getElementById('ct-un').value='';
  openModal('create-modal');
};
window.updateCTtype=()=>{document.getElementById('link-wrap').style.display=document.getElementById('ct-type').value==='channel'?'':'none';};

window.createChat=async()=>{
  const nm=document.getElementById('ct-nm').value.trim();
  const t=document.getElementById('ct-type').value;
  const unRaw=document.getElementById('ct-un').value.trim().toLowerCase().replace(/[^a-z0-9_]/g,'');
  const linked=document.getElementById('ct-linked')?.value||'';
  if(!nm) return showErr('ct-err','Введіть назву');
  if(!unRaw) return showErr('ct-err','Введіть юзернейм для пошуку');
  if(unRaw.length<3) return showErr('ct-err','Юзернейм мін. 3 символи');
  // Перевірка унікальності юзернейму
  const unSnap=await get(ref(db,`chatusernames/${unRaw}`));
  if(unSnap.exists()) return showErr('ct-err',`@${unRaw} вже зайнятий`);
  const r=push(ref(db,'chats'));
  const chatId=r.key;
  const data={name:nm,type:t,emoji:selCreateEmoji,username:unRaw,creatorUid:CU.uid,createdAt:Date.now(),members:{[CU.uid]:true}};
  if(linked&&t==='channel') data.linkedGroupId=linked;
  await set(r,data);
  await set(ref(db,`chatusernames/${unRaw}`),chatId);
  // Додаємо тільки творцю до userChats
  await set(ref(db,`userChats/${CU.uid}/${chatId}`),{joinedAt:Date.now(),type:t});
  closeModal('create-modal');
  toast(`"${nm}" (@${unRaw}) створено 🎉`);
};

/* == ACC SWITCHER == */
function renderAccSwitcher(){
  const sw=document.getElementById('acc-sw');sw.innerHTML='';
  LS.accs().forEach(a=>{
    if(a.uid===CU?.uid) return;
    const d=document.createElement('div');d.className='acc-sw-item';
    d.innerHTML=`<span style="font-size:17px">${a.emoji||'👤'}</span><div><div style="font-size:11px;font-weight:700">${esc(a.nickname||'Акаунт')}</div><div style="font-size:9px;color:var(--txt2);font-family:var(--ff-mono)">@${esc(a.username||'')}</div></div>`;
    d.onclick=e=>{e.stopPropagation();quickLogin(a);};sw.appendChild(d);
  });
  if(LS.accs().length<MAX_ACCS){
    const add=document.createElement('div');add.className='acc-sw-item add';
    add.innerHTML=`<span style="font-size:17px">+</span><div><div style="font-size:11px;font-weight:700">Додати акаунт</div></div>`;
    add.onclick=e=>{e.stopPropagation();doLogout();};sw.appendChild(add);
  }
}
window.toggleAccSw=()=>document.getElementById('acc-sw').classList.toggle('open');
document.addEventListener('click',e=>{if(!document.getElementById('cur-acc').contains(e.target))document.getElementById('acc-sw').classList.remove('open');});

/* == MODALS == */
window.openModal=id=>document.getElementById(id).classList.add('open');
window.closeModal=id=>document.getElementById(id).classList.remove('open');
document.querySelectorAll('.overlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
window.toggleSb=()=>document.getElementById('sidebar').classList.toggle('mob');

/* == EMOJI == */
function buildEmojiGrid(cid,onSel,initial){
  const c=document.getElementById(cid);if(!c)return;c.innerHTML='';
  EMOJIS.forEach(e=>{
    const b=document.createElement('button');b.className='emoji-opt'+(e===initial?' sel':'');b.textContent=e;b.type='button';
    b.onclick=()=>{c.querySelectorAll('.emoji-opt').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');onSel(e);};
    c.appendChild(b);
  });
}
buildEmojiGrid('reg-ep',e=>selRegEmoji=e,selRegEmoji);

window.openEmojiModal=target=>{
  emojiTarget=target;selModalEmoji=CP?.emoji||'😀';
  buildEmojiGrid('em-ep',e=>selModalEmoji=e,selModalEmoji);openModal('emoji-modal');
};
window.confirmEmoji=async()=>{
  if(!selModalEmoji||!CU) return;
  if(emojiTarget==='avatar'){
    await update(ref(db,`users/${CU.uid}`),{emoji:selModalEmoji});
    CP.emoji=selModalEmoji;
    document.getElementById('ca-em').textContent=selModalEmoji;
    document.getElementById('sp-av').textContent=selModalEmoji;
    upsertAcc({uid:CU.uid,emoji:selModalEmoji});toast('Аватарку змінено ✅');
  }
  closeModal('emoji-modal');
};

/* == UTILS == */
function detach(){
  if(curListener&&curChatId){
    try{off(query(ref(db,`messages/${curChatId}`),orderByChild('ts'),limitToLast(80)),'child_added',curListener);}catch{}
    curListener=null;
  }
}
function v(id){return(document.getElementById(id)?.value||'').trim();}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function text2html(s){return esc(s).replace(/\n/g,'<br>');}
function showErr(id,msg){const el=document.getElementById(id);if(!el)return;el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),4500);}
function setBtnL(id,on){const b=document.getElementById(id);if(!b)return;b.disabled=on;if(id==='l-btn')b.textContent=on?'⏳ Завантаження...':'Увійти';else if(id==='r-btn')b.textContent=on?'⏳ Завантаження...':'Зареєструватись';}
window.toast=(msg,dur=2800)=>{const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),dur);};
function fbE(code){const m={'auth/email-already-in-use':'Email вже використовується','auth/invalid-email':'Невірний email','auth/weak-password':'Слабкий пароль (мін. 6 символів)','auth/user-not-found':'Акаунт не знайдено','auth/wrong-password':'Невірний пароль','auth/invalid-credential':'Невірні дані для входу','auth/too-many-requests':'Забагато спроб. Спробуйте пізніше'};return m[code]||`Помилка: ${code}`;}

/* == SETTINGS == */
window.openSP=()=>{document.getElementById('sp').classList.add('open');renderContacts();};
window.closeSP=()=>document.getElementById('sp').classList.remove('open');
window.setFsz=(sz,btn)=>{document.documentElement.style.setProperty('--chat-font-size',sz);document.querySelectorAll('.fszb').forEach(b=>b.classList.remove('active'));btn.classList.add('active');const c=LS.cfg();c.fontSize=sz;LS.saveCfg(c);};

function buildThemeGrid(){
  const g=document.getElementById('theme-grid');if(!g)return;
  const c=LS.cfg();g.innerHTML='';
  THEMES.forEach(th=>{
    const d=document.createElement('div');
    d.className='th-opt'+(c.theme===th.id?' sel':'');
    d.style.background=th.bg;d.style.color=th.txt||'#fff';d.textContent=th.label;
    d.onclick=()=>{document.querySelectorAll('.th-opt').forEach(x=>x.classList.remove('sel'));d.classList.add('sel');applyTheme(th.id);const cc=LS.cfg();cc.theme=th.id;LS.saveCfg(cc);};
    g.appendChild(d);
  });
}
function applyTheme(id){if(id==='violet')document.documentElement.removeAttribute('data-theme');else document.documentElement.setAttribute('data-theme',id);}
function buildFontGrid(){
  const g=document.getElementById('font-grid');if(!g)return;
  const c=LS.cfg();g.innerHTML='';
  FONTS.forEach(f=>{
    const d=document.createElement('div');
    d.className='font-opt'+(c.font===f.id?' sel':'');d.style.fontFamily=f.css;d.textContent=f.label;
    d.onclick=()=>{document.querySelectorAll('.font-opt').forEach(x=>x.classList.remove('sel'));d.classList.add('sel');document.documentElement.style.setProperty('--ff-ui',f.css);const cc=LS.cfg();cc.font=f.id;cc.fontCss=f.css;LS.saveCfg(cc);};
    g.appendChild(d);
  });
}
window.toggleNotif=()=>{soundOn=!soundOn;document.getElementById('notif-tgl').classList.toggle('on',soundOn);const c=LS.cfg();c.sound=soundOn;LS.saveCfg(c);toast(soundOn?'🔔 Звуки ввімкнено':'🔕 Звуки вимкнено');};
function applySettings(){
  const c=LS.cfg();
  if(c.fontSize) document.documentElement.style.setProperty('--chat-font-size',c.fontSize);
  if(c.theme) applyTheme(c.theme);
  if(c.fontCss) document.documentElement.style.setProperty('--ff-ui',c.fontCss);
  soundOn=c.sound!==undefined?c.sound:true;
  document.getElementById('notif-tgl')?.classList.toggle('on',soundOn);
  buildThemeGrid();buildFontGrid();
}
window.saveProfile=async()=>{
  const nn=document.getElementById('sp-nn')?.value.trim();
  if(!nn||!CU) return toast('Введіть нікнейм');
  await update(ref(db,`users/${CU.uid}`),{nickname:nn});
  CP.nickname=nn;document.getElementById('ca-nm').textContent=nn;
  upsertAcc({uid:CU.uid,nickname:nn});toast('Збережено ✅');
};
</script>
</body>

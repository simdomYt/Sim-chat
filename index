/* == ВІДКРИТИ ЧАТ == */
async function openChat(chat){
  detach();
  curChatId=chat.id;curChatData=chat;
  document.querySelectorAll('.ci').forEach(el=>el.classList.toggle('active',el.dataset.id===chat.id));
  document.getElementById('welcome').style.display='none';
  const cv=document.getElementById('cv');cv.style.display='flex';
  document.getElementById('cpp').classList.remove('open');
  // Визначаємо іконку та назву
  let icon='💬',name='Чат',meta='';
  if(chat.type==='dm'){icon=chat.otherEmoji||'👤';name=chat.otherNickname||chat.otherUsername||'Користувач';meta='👤 Особисте повідомлення';}
  else if(chat.type==='global'){icon='🌍';name='🌍 Global';meta='Глобальний чат';}
  else if(chat.type==='channel'){icon=chat.emoji||'📢';name=chat.name||chat.id;meta='📢 Канал';}
  else{icon=chat.emoji||'👥';name=chat.name||chat.id;meta='👥 Група';}
  document.getElementById('hdr-av').textContent=icon;
  document.getElementById('hdr-nm').textContent=name;
  document.getElementById('hdr-mt').textContent=meta;
  // Кнопка учасників — тільки для груп/каналів
  document.getElementById('hdr-members-btn').style.display=(chat.type==='group'||chat.type==='channel')?'flex':'none';
  const isOwner=chat.creatorUid===CU?.uid;
  const isAdmin=isOwner||(chat.adminUids&&chat.adminUids[CU?.uid]);
  const canWrite=chat.type!=='channel'||isOwner||isAdmin;
  document.getElementById('iz').style.display=canWrite?'':'none';
  document.getElementById('roz').style.display=canWrite?'none':'';
  // E2E ключ
  if(!chatKeys[chat.id]) chatKeys[chat.id]=await E2E.deriveFromStr(chat.id+'_simchat',chat.id);
  const msgs=document.getElementById('msgs');
  msgs.innerHTML='';sentIds.clear();
  const mref=query(ref(db,`messages/${chat.id}`),orderByChild('ts'),limitToLast(80));
  curListener=onChildAdded(mref,async snap=>{
    const msg=snap.val();
    if(!msg||sentIds.has(snap.key)) return;
    sentIds.add(snap.key);
    let text=msg.text||'';
    if(msg.enc&&chatKeys[chat.id]){try{text=await E2E.decrypt(msg.enc,chatKeys[chat.id]);}catch{text='🔒';}}
    const no=LS.no();
    const dispNick=no[msg.uid]||msg.nickname||'User';
    renderMsg(snap.key,{...msg,text,nickname:dispNick},chat.type,isOwner||isAdmin);
    msgs.scrollTop=msgs.scrollHeight;
    if(msg.uid!==CU?.uid) playNotif();
  });
  if(window.innerWidth<=700) document.getElementById('sidebar').classList.remove('mob');
}

/* == РЕНДЕР ПОВІДОМЛЕННЯ == */
function renderMsg(key,msg,chatType,canDel){
  const isMine=msg.uid===CU?.uid;
  const time=msg.ts?new Date(msg.ts).toLocaleTimeString('uk',{hour:'2-digit',minute:'2-digit'}):'--:--';
  const d=document.createElement('div');
  d.className=`msg${isMine?' mine':''}`;
  d.dataset.key=key;
  d.dataset.uid=msg.uid;
  let body='';
  if(msg.voiceUrl){
    const bars=Array.from({length:18},(_,i)=>`<div class="voice-bar" style="animation-delay:${i*0.065}s"></div>`).join('');
    body=`<div class="voice-msg" onclick="playAudio('${msg.voiceUrl}')"><div class="voice-play">▶️</div><div class="voice-bars">${bars}</div><span class="voice-dur">${msg.dur||'0:00'}</span></div>`;
  }else if(msg.videoUrl){
    body=`<div class="video-circle"><video src="${esc(msg.videoUrl)}" playsinline></video><div class="vid-ov" onclick="this.parentElement.querySelector('video').play();this.style.display='none'">▶️</div></div>`;
  }else{
    body=`<div class="msg-txt">${esc(text2html(msg.text||''))}</div>`;
  }
  if(msg.enc) body+=`<div class="msg-enc">🔒 E2E</div>`;
  let linkBtn='';
  if(chatType==='channel'&&curChatData?.linkedGroupId){
    const lg=myChats.find(c=>c.id===curChatData.linkedGroupId);
    if(lg) linkBtn=`<div class="ch-link-btn" onclick="openChatById('${lg.id}')">💬 Коменти · ${esc(lg.name||lg.id)}</div>`;
  }
  const showUser=chatType!=='channel'||canDel;
  const hdr=showUser
    ?`<div class="msg-hdr"><span class="msg-nm" onclick="openUserModalByMsg('${msg.uid}','${esc(msg.username||'')}','${esc(msg.nickname||'')}','${msg.emoji||'👤'}')">${esc(msg.nickname||'User')}</span><span class="msg-tag">${msg.username?`@${esc(msg.username)}`:''}</span><span class="msg-t">${time}</span></div>`
    :`<div style="display:flex;justify-content:flex-end;margin-bottom:2px"><span class="msg-t">${time}</span></div>`;
  const delBtn=(isMine||canDel)?`<button class="mact del" title="Видалити" onclick="deleteMsg('${key}')">🗑️</button>`:'';
  const banBtn=(!isMine&&canDel)?`<button class="mact ban" title="Бан" onclick="banMember('${msg.uid}','${esc(msg.username||'')}')">🔨</button>`:'';
  const userBtn=!isMine?`<button class="mact" title="Профіль" onclick="openUserModalByMsg('${msg.uid}','${esc(msg.username||'')}','${esc(msg.nickname||'')}','${msg.emoji||'👤'}')">👤</button>`:'';
  d.innerHTML=`<div class="msg-av">${msg.emoji||'👤'}</div><div class="msg-body">${hdr}${body}${linkBtn}</div><div class="msg-acts">${userBtn}${banBtn}${delBtn}</div>`;
  document.getElementById('msgs').appendChild(d);
}

/* == ВІДПРАВКА == */
window.sendMsg=async()=>{
  const inp=document.getElementById('mi');
  const txt=inp.value.trim();
  if(!txt||!curChatId||!CU||!CP) return;
  const btn=document.getElementById('sb2');btn.disabled=true;
  try{
    const key=chatKeys[curChatId];
    const payload={uid:CU.uid,nickname:CP.nickname,username:CP.username,emoji:CP.emoji,ts:Date.now()};
    if(key){payload.enc=await E2E.encrypt(txt,key);}else{payload.text=txt;}
    await push(ref(db,`messages/${curChatId}`),payload);
    await update(ref(db,`chats/${curChatId}`),{lastMsg:txt.slice(0,60),lastTs:Date.now()});
    inp.value='';inp.style.height='';
  }catch(e){toast('Помилка: '+e.message);}
  finally{btn.disabled=false;inp.focus();}
};
window.miKey=e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();window.sendMsg();}};
window.miResize=el=>{el.style.height='auto';el.style.height=Math.min(el.scrollHeight,110)+'px';};


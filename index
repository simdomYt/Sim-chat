          <div class="member-item-info"><div class="member-item-nm" style="font-family:var(--ff-mono);font-size:10px">${uid}</div></div>
          <button class="mact-sm" title="Розбанити" onclick="unbanMember('${uid}')">🔓</button>
        </div>`).join('');
      }
    }
  }

  const groups=myChats.filter(c=>c.type==='group');
  body.innerHTML=`
    <div class="cpp-av">${chat.type==='dm'?chat.otherEmoji||'👤':chat.emoji||'📢'}</div>
    <div class="cpp-name">${esc(chat.type==='dm'?(chat.otherNickname||'Користувач'):(chat.name||chat.id))}</div>
    <div class="cpp-sub">${chat.type==='channel'?'📢 Канал':'👥 Група'}${chat.username?` · @${chat.username}`:''} · ${new Date(chat.createdAt||0).toLocaleDateString('uk')}</div>
    ${isOwner?`
      <div class="ss-title" style="font-size:9px;color:var(--txt2);font-family:var(--ff-mono);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Управління (власник)</div>
      <div class="form-group"><label>Нова назва</label><input class="form-input" id="cpp-newnm" value="${esc(chat.name||'')}"></div>
      <div class="form-group"><label>Юзернейм</label><div class="input-pfx"><span>@</span><input class="form-input" id="cpp-newun" value="${esc(chat.username||'')}" placeholder="groupname"></div></div>
      <button class="btn-s" onclick="saveChatSettings()">Зберегти налаштування</button>
      ${chat.type==='channel'?`
        <div class="form-group" style="margin-top:10px"><label>Прив'язана група (коменти)</label>

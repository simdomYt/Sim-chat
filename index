<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Sim Chat</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;600;700;900&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --ff-ui:'Unbounded',sans-serif;--ff-mono:'IBM Plex Mono',monospace;
  --bg0:#05030e;--bg1:#0c0920;--bg2:#13103a;--bg3:#1a1650;
  --panel:rgba(12,9,32,0.97);--border:rgba(139,92,246,0.15);--border2:rgba(139,92,246,0.35);
  --acc1:#7c3aed;--acc2:#4f46e5;--acc3:#06b6d4;
  --neon1:#a78bfa;--neon2:#818cf8;
  --txt0:#f0ecff;--txt1:#9b91cc;--txt2:#5a527a;
  --danger:#f43f5e;--success:#10b981;
  --r-sm:8px;--r-md:12px;--r-lg:18px;--r-xl:24px;
  --chat-font-size:14px;--sidebar-w:290px;
  --chat-bg:linear-gradient(160deg,#05030e 0%,#0c0920 50%,#110828 100%);
}
[data-theme="dark"]{--bg0:#080808;--bg1:#111;--bg2:#1a1a1a;--bg3:#222;--panel:rgba(10,10,10,0.97);--border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.2);--acc1:#444;--acc2:#555;--acc3:#888;--neon1:#ddd;--neon2:#aaa;--txt0:#fff;--txt1:#aaa;--txt2:#555;--chat-bg:linear-gradient(160deg,#080808,#111,#0f0f0f)}
[data-theme="white"]{--bg0:#f5f3ff;--bg1:#fff;--bg2:#ede9ff;--bg3:#e0daff;--panel:rgba(255,255,255,0.98);--border:rgba(100,80,200,0.15);--border2:rgba(100,80,200,0.4);--acc1:#6d28d9;--acc2:#4338ca;--acc3:#0891b2;--neon1:#7c3aed;--neon2:#4f46e5;--txt0:#1e1b4b;--txt1:#5b5478;--txt2:#9896b0;--chat-bg:linear-gradient(160deg,#f5f3ff,#ede9ff,#e8e5f8)}
[data-theme="green"]{--bg0:#030b05;--bg1:#071410;--bg2:#0d1f18;--bg3:#132a22;--panel:rgba(5,18,12,0.97);--border:rgba(16,185,129,0.15);--border2:rgba(16,185,129,0.35);--acc1:#059669;--acc2:#047857;--acc3:#06b6d4;--neon1:#34d399;--neon2:#6ee7b7;--txt0:#ecfdf5;--txt1:#6ee7b7;--txt2:#2d7a5a;--chat-bg:linear-gradient(160deg,#030b05,#071410,#0a1c14)}
[data-theme="blue"]{--bg0:#020b18;--bg1:#061525;--bg2:#0a2035;--bg3:#0e2b47;--panel:rgba(4,14,30,0.97);--border:rgba(59,130,246,0.15);--border2:rgba(59,130,246,0.35);--acc1:#2563eb;--acc2:#1d4ed8;--acc3:#06b6d4;--neon1:#60a5fa;--neon2:#93c5fd;--txt0:#eff6ff;--txt1:#93c5fd;--txt2:#2a5a9a;--chat-bg:linear-gradient(160deg,#020b18,#061525,#071c33)}
[data-theme="yellow"]{--bg0:#0f0b00;--bg1:#1a1400;--bg2:#261e00;--bg3:#332800;--panel:rgba(20,15,0,0.97);--border:rgba(245,158,11,0.15);--border2:rgba(245,158,11,0.35);--acc1:#d97706;--acc2:#b45309;--acc3:#ef4444;--neon1:#fbbf24;--neon2:#fde68a;--txt0:#fffbeb;--txt1:#fde68a;--txt2:#7a5f1a;--chat-bg:linear-gradient(160deg,#0f0b00,#1a1400,#201900)}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;background:var(--bg0);color:var(--txt0);font-family:var(--ff-ui);overflow:hidden}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--txt2);border-radius:2px}
body::after{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9998;opacity:.5}

/* == AUTH == */
#auth-screen{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:radial-gradient(ellipse 70% 60% at 50% 40%,rgba(124,58,237,0.1),transparent 70%),var(--bg0);z-index:100;overflow-y:auto;padding:20px 16px}
#auth-screen.hidden{display:none!important}
.auth-box{width:100%;max-width:400px;background:var(--panel);border:1px solid var(--border);border-radius:var(--r-xl);padding:32px 28px;backdrop-filter:blur(24px);box-shadow:0 40px 80px rgba(0,0,0,.6);animation:slideUp .5s cubic-bezier(.16,1,.3,1)}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.auth-logo{text-align:center;margin-bottom:20px}
.auth-logo-mark{width:50px;height:50px;margin:0 auto 10px;background:linear-gradient(135deg,var(--acc1),var(--acc2));border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;box-shadow:0 0 28px rgba(124,58,237,.5)}
.auth-logo h1{font-size:18px;font-weight:900;background:linear-gradient(135deg,var(--neon1),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-1px}
.auth-logo p{font-size:9px;color:var(--txt2);font-family:var(--ff-mono);margin-top:3px}
.auth-tabs{display:flex;gap:4px;background:rgba(0,0,0,.3);border-radius:var(--r-sm);padding:4px;margin-bottom:18px}
.auth-tab{flex:1;padding:7px 4px;background:none;border:none;color:var(--txt2);font-family:var(--ff-ui);font-size:10px;font-weight:700;cursor:pointer;border-radius:6px;transition:all .2s;letter-spacing:.3px}
.auth-tab.active{background:linear-gradient(135deg,rgba(124,58,237,.3),rgba(79,70,229,.2));color:var(--txt0)}
.form-group{margin-bottom:11px}
.form-group label{display:block;font-size:9px;font-weight:700;color:var(--txt1);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px;font-family:var(--ff-mono)}
.form-input{width:100%;padding:9px 12px;background:rgba(0,0,0,.35);border:1px solid var(--border);border-radius:var(--r-sm);color:var(--txt0);font-family:var(--ff-mono);font-size:12px;outline:none;transition:all .2s}
.form-input:focus{border-color:var(--acc1);box-shadow:0 0 0 3px rgba(124,58,237,.12)}
.form-input::placeholder{color:var(--txt2)}
select.form-input option{background:var(--bg1);color:var(--txt0)}
.input-pfx{position:relative}
.input-pfx span{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--acc1);font-family:var(--ff-mono);font-size:12px;pointer-events:none}
.input-pfx .form-input{padding-left:26px}
.emoji-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:4px;padding:9px;background:rgba(0,0,0,.3);border:1px solid var(--border);border-radius:var(--r-sm);max-height:108px;overflow-y:auto}
.emoji-opt{display:flex;align-items:center;justify-content:center;width:30px;height:30px;font-size:18px;cursor:pointer;border-radius:6px;border:2px solid transparent;transition:all .15s;background:none}
.emoji-opt:hover{background:rgba(124,58,237,.15);transform:scale(1.15)}
.emoji-opt.sel{border-color:var(--acc1);background:rgba(124,58,237,.2)}
.btn-p{width:100%;padding:11px;background:linear-gradient(135deg,var(--acc1),var(--acc2));border:none;border-radius:var(--r-sm);color:#fff;font-family:var(--ff-ui);font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;letter-spacing:.3px;box-shadow:0 4px 18px rgba(124,58,237,.35);margin-top:6px}
.btn-p:hover{transform:translateY(-1px);box-shadow:0 8px 26px rgba(124,58,237,.5)}
.btn-p:disabled{opacity:.4;cursor:not-allowed;transform:none}
.btn-s{width:100%;padding:9px;background:rgba(124,58,237,.1);border:1px solid var(--border2);border-radius:var(--r-sm);color:var(--neon1);font-family:var(--ff-ui);font-size:11px;font-weight:700;cursor:pointer;transition:all .2s;margin-bottom:5px}
.btn-s:hover{background:rgba(124,58,237,.2)}
.btn-d{width:100%;padding:9px;background:rgba(244,63,94,.1);border:1px solid rgba(244,63,94,.25);border-radius:var(--r-sm);color:var(--danger);font-family:var(--ff-ui);font-size:11px;font-weight:700;cursor:pointer;transition:all .2s;margin-bottom:5px}
.btn-d:hover{background:rgba(244,63,94,.2)}
.auth-err{font-size:10px;color:var(--danger);text-align:center;margin-top:9px;font-family:var(--ff-mono);display:none;line-height:1.4}
.auth-err.show{display:block}
.saved-accs{margin-bottom:14px;display:none}
.saved-accs.has{display:block}
.saved-accs-lbl{font-size:9px;color:var(--txt2);text-transform:uppercase;letter-spacing:1px;font-family:var(--ff-mono);margin-bottom:5px}
.sav-acc{display:flex;align-items:center;gap:8px;padding:7px 10px;background:rgba(0,0,0,.3);border:1px solid var(--border);border-radius:var(--r-sm);cursor:pointer;transition:all .2s;margin-bottom:4px}
.sav-acc:hover{border-color:var(--border2);background:rgba(124,58,237,.08)}
.sav-acc-rm{width:18px;height:18px;display:flex;align-items:center;justify-content:center;background:none;border:none;color:var(--txt2);cursor:pointer;border-radius:4px;font-size:11px;transition:all .15s;flex-shrink:0}
.sav-acc-rm:hover{color:var(--danger)}

/* == APP == */
#app{display:none;height:100vh;overflow:hidden}
#app.on{display:flex}

/* == SIDEBAR == */
.sidebar{width:var(--sidebar-w);min-width:var(--sidebar-w);height:100vh;background:var(--panel);border-right:1px solid var(--border);display:flex;flex-direction:column;position:relative;z-index:10;transition:transform .3s cubic-bezier(.16,1,.3,1)}
.sb-head{padding:12px 13px 9px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.sb-logo{width:28px;height:28px;background:linear-gradient(135deg,var(--acc1),var(--acc2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.sb-title{font-size:13px;font-weight:900;background:linear-gradient(135deg,var(--neon1),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-.5px;flex:1}
.sb-search{padding:9px 11px;border-bottom:1px solid var(--border);position:relative}
.srch{width:100%;padding:7px 11px;background:rgba(0,0,0,.3);border:1px solid var(--border);border-radius:var(--r-sm);color:var(--txt0);font-family:var(--ff-mono);font-size:11px;outline:none;transition:all .2s}
.srch:focus{border-color:var(--acc1)}
/* Результати пошуку */
.search-results{position:absolute;top:100%;left:11px;right:11px;background:var(--panel);border:1px solid var(--border2);border-radius:var(--r-sm);z-index:50;max-height:240px;overflow-y:auto;box-shadow:0 12px 40px rgba(0,0,0,.5);display:none}
.search-results.show{display:block}
.sr-section{font-size:8px;font-weight:700;color:var(--txt2);text-transform:uppercase;letter-spacing:1px;font-family:var(--ff-mono);padding:8px 12px 4px}
.sr-item{display:flex;align-items:center;gap:9px;padding:9px 12px;cursor:pointer;transition:background .15s;border-bottom:1px solid var(--border)}
.sr-item:last-child{border-bottom:none}
.sr-item:hover{background:var(--bg3)}
.sr-av{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.sr-info{flex:1;min-width:0}
.sr-name{font-size:11px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sr-sub{font-size:9px;color:var(--txt2);font-family:var(--ff-mono)}
.sr-action{font-size:9px;color:var(--acc3);font-family:var(--ff-mono);white-space:nowrap;font-weight:700}

.sb-tabs{display:flex;padding:6px 9px;gap:3px;border-bottom:1px solid var(--border)}
.stab{flex:1;padding:5px 3px;background:none;border:none;color:var(--txt2);font-family:var(--ff-ui);font-size:8px;font-weight:700;cursor:pointer;border-radius:5px;transition:all .2s;text-transform:uppercase;letter-spacing:.4px}
.stab.active{background:rgba(124,58,237,.2);color:var(--neon1)}

/* == CHAT LIST — КЛЮЧОВА СЕКЦІЯ == */
.chat-list{flex:1;overflow-y:auto;overflow-x:hidden;padding:5px;display:flex;flex-direction:column;min-height:0;width:100%}
.ci{display:flex;flex-direction:row;align-items:center;gap:8px;padding:8px;border-radius:var(--r-sm);cursor:pointer;transition:all .15s;position:relative;width:100%;flex-shrink:0;min-height:52px}
.ci:hover{background:var(--bg3)}
.ci.active{background:rgba(124,58,237,.13)}
.ci.active::before{content:'';position:absolute;left:0;top:4px;bottom:4px;width:3px;background:var(--acc1);border-radius:0 2px 2px 0}
.ci-av{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.ci-av-dm{background:linear-gradient(135deg,rgba(6,182,212,.3),rgba(16,185,129,.25))}
.ci-av-g{background:linear-gradient(135deg,rgba(124,58,237,.25),rgba(79,70,229,.25))}
.ci-av-c{background:linear-gradient(135deg,rgba(6,182,212,.25),rgba(59,130,246,.25))}
.ci-av-gr{background:linear-gradient(135deg,rgba(236,72,153,.2),rgba(124,58,237,.2))}
.ci-av-gl{background:linear-gradient(135deg,rgba(16,185,129,.2),rgba(6,182,212,.2))}
.ci-inf{flex:1;min-width:0}
.ci-name{font-size:12px;font-weight:700;color:var(--txt0);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ci-prev{font-size:10px;color:var(--txt2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:var(--ff-mono);margin-top:1px}
.ci-unread{min-width:18px;height:18px;border-radius:9px;background:var(--acc1);color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 4px;flex-shrink:0}

.sb-new{padding:6px 7px;border-top:1px solid var(--border)}
.new-cb{display:flex;align-items:center;gap:6px;padding:7px 10px;background:rgba(124,58,237,.08);border:1px dashed var(--border2);border-radius:var(--r-sm);color:var(--txt1);font-family:var(--ff-ui);font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;width:100%}
.new-cb:hover{background:rgba(124,58,237,.18);color:var(--neon1)}
.acc-zone{padding:7px;border-top:1px solid var(--border)}
.curr-acc{display:flex;align-items:center;gap:8px;padding:8px;border-radius:var(--r-sm);background:rgba(0,0,0,.3);border:1px solid var(--border);cursor:pointer;transition:all .2s;position:relative}
.curr-acc:hover{border-color:var(--border2)}
.acc-sw{display:none;position:absolute;bottom:100%;left:0;right:0;background:var(--panel);border:1px solid var(--border2);border-radius:var(--r-sm);overflow:hidden;backdrop-filter:blur(20px);box-shadow:0 -20px 40px rgba(0,0,0,.5);z-index:50;animation:sdown .2s ease;margin-bottom:4px}
@keyframes sdown{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.acc-sw.open{display:block}
.acc-sw-item{display:flex;align-items:center;gap:8px;padding:8px 12px;cursor:pointer;transition:background .15s;border-bottom:1px solid var(--border)}
.acc-sw-item:last-child{border-bottom:none}
.acc-sw-item:hover{background:var(--bg3)}
.acc-sw-item.add{color:var(--acc1)}
.acc-btns{display:flex;gap:3px}
.acc-btn{width:24px;height:24px;display:flex;align-items:center;justify-content:center;background:none;border:1px solid var(--border);border-radius:5px;color:var(--txt2);cursor:pointer;font-size:12px;transition:all .15s}
.acc-btn:hover{border-color:var(--acc1);color:var(--neon1)}

/* == MAIN AREA == */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--chat-bg);position:relative}
.chat-hdr{padding:11px 16px;background:rgba(12,9,32,.85);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:9px;backdrop-filter:blur(20px);z-index:5;flex-shrink:0}
.hamburger{display:none;background:none;border:none;color:var(--txt0);font-size:18px;cursor:pointer;padding:4px}
.hdr-av{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;background:linear-gradient(135deg,rgba(124,58,237,.25),rgba(79,70,229,.25));flex-shrink:0;cursor:pointer;transition:opacity .2s}
.hdr-av:hover{opacity:.75}
.hdr-inf{flex:1;min-width:0}
.hdr-name{font-size:13px;font-weight:700;color:var(--txt0);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hdr-meta{font-size:10px;color:var(--txt2);font-family:var(--ff-mono)}
.hdr-acts{display:flex;gap:5px}
.hbtn{width:30px;height:30px;display:flex;align-items:center;justify-content:center;background:none;border:1px solid var(--border);border-radius:7px;color:var(--txt1);cursor:pointer;font-size:14px;transition:all .15s}
.hbtn:hover{border-color:var(--acc1);color:var(--neon1);background:rgba(124,58,237,.1)}

/* == MESSAGES == */
.msgs{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:1px;scroll-behavior:smooth}
.msg-day{display:flex;align-items:center;gap:10px;margin:12px 0 5px;color:var(--txt2);font-size:9px;font-family:var(--ff-mono)}
.msg-day::before,.msg-day::after{content:'';flex:1;height:1px;background:var(--border)}
.msg{display:flex;gap:8px;padding:3px 5px;border-radius:var(--r-sm);transition:background .15s;animation:min .25s cubic-bezier(.16,1,.3,1);position:relative}
@keyframes min{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.msg:hover{background:rgba(255,255,255,.025)}
.msg:hover .msg-acts{opacity:1}
.msg-av{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;align-self:flex-end;background:rgba(124,58,237,.1)}
.msg-body{display:flex;flex-direction:column;flex:1;min-width:0}
.msg-hdr{display:flex;align-items:baseline;gap:6px;margin-bottom:2px;flex-wrap:wrap}
.msg-nm{font-size:11px;font-weight:700;color:var(--neon1);cursor:pointer}
.msg-nm:hover{text-decoration:underline}
.msg-tag{font-size:10px;color:var(--txt2);font-family:var(--ff-mono)}
.msg-t{font-size:9px;color:var(--txt2);font-family:var(--ff-mono);margin-left:auto;flex-shrink:0}
.msg-txt{font-size:var(--chat-font-size);color:var(--txt0);line-height:1.55;word-break:break-word}
.msg.mine .msg-nm{color:var(--acc3)}
.msg.mine .msg-txt{background:linear-gradient(135deg,rgba(59,130,246,.13),rgba(124,58,237,.09));border:1px solid rgba(59,130,246,.18);padding:7px 11px;border-radius:11px 11px 3px 11px;display:inline-block}
.msg-acts{position:absolute;right:8px;top:50%;transform:translateY(-50%);display:flex;gap:2px;opacity:0;transition:opacity .15s;background:var(--panel);border:1px solid var(--border);border-radius:7px;padding:3px}
.mact{width:24px;height:24px;display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;border-radius:5px;font-size:12px;transition:all .15s;color:var(--txt1)}
.mact:hover{background:var(--bg3)}
.mact.del:hover{color:var(--danger)}
.mact.ban:hover{color:var(--danger)}
.msg-enc{font-size:9px;color:var(--success);font-family:var(--ff-mono);margin-top:2px}
.ch-link-btn{display:inline-flex;align-items:center;gap:5px;margin-top:5px;padding:4px 10px;background:rgba(124,58,237,.15);border:1px solid var(--border2);border-radius:20px;color:var(--neon1);font-size:10px;font-family:var(--ff-mono);cursor:pointer;transition:all .2s}
.ch-link-btn:hover{background:rgba(124,58,237,.28)}

/* == VOICE/VIDEO == */
.voice-msg{display:flex;align-items:center;gap:8px;padding:7px 11px;background:rgba(124,58,237,.1);border:1px solid var(--border);border-radius:12px;cursor:pointer;transition:all .2s;max-width:240px}
.voice-msg:hover{background:rgba(124,58,237,.2)}
.voice-play{width:28px;height:28px;border-radius:50%;background:var(--acc1);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
.voice-bars{flex:1;height:22px;display:flex;align-items:center;gap:1.5px}
.voice-bar{width:2px;border-radius:2px;background:var(--neon1);animation:vbar 1.2s ease-in-out infinite}
@keyframes vbar{0%,100%{height:3px}50%{height:14px}}
.voice-dur{font-size:10px;color:var(--txt1);font-family:var(--ff-mono)}
.video-circle{width:160px;height:160px;border-radius:50%;overflow:hidden;border:3px solid var(--acc1);cursor:pointer;position:relative;flex-shrink:0}
.video-circle video{width:100%;height:100%;object-fit:cover}
.vid-ov{position:absolute;inset:0;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;font-size:28px;transition:opacity .2s}
.vid-ov:hover{opacity:.7}

/* == INPUT == */
.inp-area{padding:9px 12px;background:rgba(12,9,32,.92);border-top:1px solid var(--border);backdrop-filter:blur(20px);flex-shrink:0}
.inp-row{display:flex;gap:6px;align-items:flex-end}
.inp-wrap{flex:1;background:rgba(0,0,0,.35);border:1px solid var(--border);border-radius:var(--r-md);padding:8px 11px;transition:all .2s;display:flex;align-items:flex-end;gap:7px}
.inp-wrap:focus-within{border-color:var(--acc1);box-shadow:0 0 0 2px rgba(124,58,237,.1)}
.msg-inp{flex:1;background:none;border:none;color:var(--txt0);font-family:var(--ff-ui);font-size:13px;outline:none;resize:none;max-height:110px;line-height:1.4}
.msg-inp::placeholder{color:var(--txt2)}
.inp-icon{background:none;border:none;color:var(--txt2);cursor:pointer;font-size:16px;padding:2px;transition:color .15s;flex-shrink:0;line-height:1}
.inp-icon:hover{color:var(--neon1)}
.send-btn{width:38px;height:38px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--acc1),var(--acc2));border:none;border-radius:var(--r-sm);color:#fff;cursor:pointer;font-size:16px;transition:all .2s;box-shadow:0 4px 14px rgba(124,58,237,.4);flex-shrink:0}
.send-btn:hover{transform:scale(1.07)}
.send-btn:disabled{opacity:.35;cursor:not-allowed;transform:none}

/* == RECORDING == */
.rec-ui{display:none;align-items:center;gap:9px;padding:9px 12px;background:rgba(244,63,94,.07);border-top:1px solid rgba(244,63,94,.2);flex-shrink:0}
.rec-ui.on{display:flex}
.rec-dot{width:9px;height:9px;border-radius:50%;background:var(--danger);animation:blink .8s ease-in-out infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}
.rec-timer{font-family:var(--ff-mono);font-size:12px;color:var(--danger);font-weight:600}
.rec-cancel{background:none;border:1px solid var(--border);border-radius:6px;color:var(--txt1);font-family:var(--ff-ui);font-size:10px;cursor:pointer;padding:4px 9px;transition:all .15s}
.rec-cancel:hover{border-color:var(--danger);color:var(--danger)}
.rec-send{background:var(--danger);border:none;border-radius:6px;color:#fff;font-family:var(--ff-ui);font-size:10px;cursor:pointer;padding:4px 9px;font-weight:700}
.ch-ro{text-align:center;padding:10px;color:var(--txt2);font-size:11px;font-family:var(--ff-mono);border-top:1px solid var(--border);background:rgba(12,9,32,.9);flex-shrink:0}

/* == SETTINGS PANEL == */
.sp{position:absolute;top:0;right:0;bottom:0;width:300px;background:var(--panel);border-left:1px solid var(--border);backdrop-filter:blur(24px);z-index:20;transform:translateX(100%);transition:transform .3s cubic-bezier(.16,1,.3,1);display:flex;flex-direction:column;overflow:hidden}
.sp.open{transform:translateX(0)}
.sp-head{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.sp-head h3{font-size:13px;font-weight:700}
.cl-btn{width:24px;height:24px;display:flex;align-items:center;justify-content:center;background:none;border:1px solid var(--border);border-radius:5px;color:var(--txt2);cursor:pointer;font-size:14px;transition:all .15s}
.cl-btn:hover{border-color:var(--acc1);color:var(--txt0)}
.sp-body{flex:1;overflow-y:auto;padding:16px}
.ss{margin-bottom:22px}
.ss-title{font-size:9px;font-weight:700;color:var(--txt2);text-transform:uppercase;letter-spacing:1px;font-family:var(--ff-mono);margin-bottom:9px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.ss-opt{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid rgba(124,58,246,.05)}
.ss-lbl{font-size:12px;color:var(--txt1)}
.fsz-btns{display:flex;gap:3px}
.fszb{padding:4px 8px;background:rgba(0,0,0,.3);border:1px solid var(--border);border-radius:5px;color:var(--txt2);font-family:var(--ff-ui);font-size:10px;font-weight:700;cursor:pointer;transition:all .15s}
.fszb.active{background:rgba(124,58,237,.2);border-color:var(--acc1);color:var(--neon1)}
.theme-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:7px}
.th-opt{padding:8px 5px;border-radius:8px;border:2px solid transparent;cursor:pointer;transition:all .15s;text-align:center;font-size:10px;font-weight:700}
.th-opt.sel{border-color:var(--acc1);box-shadow:0 0 10px rgba(124,58,237,.4)}
.font-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-top:7px}
.font-opt{padding:7px;background:rgba(0,0,0,.25);border:1px solid var(--border);border-radius:7px;cursor:pointer;text-align:center;font-size:10px;transition:all .15s;color:var(--txt1)}
.font-opt.sel{border-color:var(--acc1);color:var(--neon1);background:rgba(124,58,237,.1)}
.av-big{font-size:44px;text-align:center;padding:10px;background:rgba(0,0,0,.2);border-radius:var(--r-sm);border:1px solid var(--border);margin-bottom:7px}
.toggle-row{display:flex;align-items:center;gap:8px;cursor:pointer;padding:7px 0}
.toggle{width:34px;height:18px;background:rgba(0,0,0,.4);border:1px solid var(--border);border-radius:9px;position:relative;transition:all .2s;flex-shrink:0}
.toggle::after{content:'';position:absolute;top:2px;left:2px;width:12px;height:12px;border-radius:50%;background:var(--txt2);transition:all .2s}
.toggle.on{background:var(--acc1);border-color:var(--acc1)}
.toggle.on::after{transform:translateX(16px);background:#fff}
.ct-list{display:flex;flex-direction:column;gap:4px;margin-top:7px}
.ct-item{display:flex;align-items:center;gap:7px;padding:7px 9px;background:rgba(0,0,0,.2);border:1px solid var(--border);border-radius:var(--r-sm);cursor:pointer;transition:background .15s}
.ct-item:hover{background:rgba(124,58,237,.08)}
.ct-item-info{flex:1;min-width:0}
.ct-item-nm{font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ct-item-tg{font-size:9px;color:var(--txt2);font-family:var(--ff-mono)}
.ct-rm{background:none;border:none;color:var(--txt2);cursor:pointer;font-size:13px;padding:2px;flex-shrink:0}
.ct-rm:hover{color:var(--danger)}

/* == CHAT PROFILE PANEL == */
.cpp{position:absolute;inset:0;background:var(--panel);backdrop-filter:blur(24px);z-index:25;transform:translateY(100%);transition:transform .3s cubic-bezier(.16,1,.3,1);display:flex;flex-direction:column;overflow:hidden}
.cpp.open{transform:translateY(0)}
.cpp-head{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.cpp-body{flex:1;overflow-y:auto;padding:22px}
.cpp-av{font-size:60px;text-align:center;margin-bottom:10px}
.cpp-name{font-size:18px;font-weight:900;text-align:center;margin-bottom:3px;background:linear-gradient(135deg,var(--neon1),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.cpp-sub{font-size:10px;color:var(--txt2);font-family:var(--ff-mono);text-align:center;margin-bottom:20px}
.adm-item{display:flex;align-items:center;gap:7px;padding:7px 9px;background:rgba(0,0,0,.2);border:1px solid var(--border);border-radius:var(--r-sm);margin-bottom:4px}
.adm-item span{flex:1;font-size:11px;font-family:var(--ff-mono)}
.adm-rm{background:none;border:none;color:var(--txt2);cursor:pointer;font-size:13px}
.adm-rm:hover{color:var(--danger)}
.link-badge{display:flex;align-items:center;gap:8px;padding:9px 12px;background:rgba(124,58,237,.1);border:1px solid var(--border2);border-radius:var(--r-sm);cursor:pointer;transition:all .2s;margin-top:8px;font-size:12px}
.link-badge:hover{background:rgba(124,58,237,.2)}
/* Учасники групи */
.member-item{display:flex;align-items:center;gap:8px;padding:8px 10px;background:rgba(0,0,0,.2);border:1px solid var(--border);border-radius:var(--r-sm);margin-bottom:4px}
.member-item-info{flex:1;min-width:0}
.member-item-nm{font-size:11px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.member-item-tg{font-size:9px;color:var(--txt2);font-family:var(--ff-mono)}
.member-role{font-size:8px;padding:2px 6px;border-radius:4px;font-weight:700;font-family:var(--ff-mono)}
.member-role.owner{background:rgba(245,158,11,.2);color:#fbbf24}
.member-role.admin{background:rgba(124,58,237,.2);color:var(--neon1)}
.member-role.member{background:rgba(90,82,122,.15);color:var(--txt2)}
.member-acts{display:flex;gap:3px}
.mact-sm{width:22px;height:22px;display:flex;align-items:center;justify-content:center;background:none;border:1px solid var(--border);border-radius:5px;color:var(--txt2);cursor:pointer;font-size:11px;transition:all .15s}
.mact-sm:hover{border-color:var(--acc1);color:var(--neon1)}
.mact-sm.ban-btn:hover{border-color:var(--danger);color:var(--danger)}

/* == MODAL == */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.7);backdrop-filter:blur(8px);z-index:200;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s;padding:16px}
.overlay.open{opacity:1;pointer-events:all}
.modal{background:var(--panel);border:1px solid var(--border2);border-radius:var(--r-xl);padding:24px;width:100%;max-width:380px;box-shadow:0 40px 80px rgba(0,0,0,.6);transform:scale(.95);transition:transform .2s;max-height:90vh;overflow-y:auto}
.overlay.open .modal{transform:scale(1)}
.modal h3{font-size:14px;font-weight:700;margin-bottom:16px}
.modal-btns{display:flex;gap:6px;margin-top:12px}
.modal-btns .btn-s,.modal-btns .btn-p{flex:1;margin-top:0;margin-bottom:0}

/* == TOAST == */
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(70px);background:var(--panel);border:1px solid var(--border2);color:var(--txt0);padding:8px 16px;border-radius:30px;font-size:11px;font-family:var(--ff-mono);backdrop-filter:blur(20px);box-shadow:0 8px 30px rgba(0,0,0,.4);z-index:9997;transition:transform .3s cubic-bezier(.16,1,.3,1),opacity .3s;opacity:0}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}

/* == WELCOME == */
#welcome{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;background:var(--chat-bg);position:relative;overflow:hidden}
.w-orb{position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none}
.w-orb-1{width:400px;height:400px;background:rgba(124,58,237,.06);top:-150px;right:-80px}
.w-orb-2{width:320px;height:320px;background:rgba(59,130,246,.05);bottom:-100px;left:-60px}
.w-cont{text-align:center;position:relative;z-index:1;animation:fi .6s ease}
@keyframes fi{from{opacity:0}to{opacity:1}}
.w-logo{width:68px;height:68px;margin:0 auto 16px;background:linear-gradient(135deg,var(--acc1),var(--acc2));border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:34px;box-shadow:0 0 50px rgba(124,58,237,.4);animation:pulse 3s ease-in-out infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 35px rgba(124,58,237,.4)}50%{box-shadow:0 0 70px rgba(124,58,237,.6)}}
.w-cont h2{font-size:22px;font-weight:900;background:linear-gradient(135deg,var(--neon1),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:6px;letter-spacing:-1px}
.w-cont p{font-size:10px;color:var(--txt2);font-family:var(--ff-mono);line-height:1.7}

/* == USER PROFILE MODAL (більший) == */
.user-profile-av{font-size:56px;text-align:center;margin-bottom:10px}
.user-profile-nm{font-size:16px;font-weight:900;text-align:center;background:linear-gradient(135deg,var(--neon1),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:3px}
.user-profile-tg{font-size:11px;color:var(--txt2);font-family:var(--ff-mono);text-align:center;margin-bottom:16px}
.user-action-row{display:flex;gap:6px;margin-bottom:8px}
.user-action-row .btn-s,.user-action-row .btn-d,.user-action-row .btn-p{flex:1;margin-bottom:0}

@media(max-width:700px){
  :root{--sidebar-w:100%}
  .sidebar{position:fixed;inset:0;z-index:30;transform:translateX(-100%)}
  .sidebar.mob{transform:translateX(0)}
  .hamburger{display:flex!important}
  .sp{width:100%}
  .cpp{border-radius:0}
}
</style>
</head>
<body>

<div id="auth-screen">
<div class="auth-box">
  <div class="auth-logo">
    <div class="auth-logo-mark">💬</div>
    <h1>Sim Chat</h1>
    <p>// end-to-end encrypted</p>
  </div>
  <div class="saved-accs" id="sav-blk">
    <div class="saved-accs-lbl">Збережені акаунти</div>
    <div id="sav-list"></div>
  </div>
  <div class="auth-tabs">
    <button class="auth-tab active" onclick="authTab('login')">Увійти</button>
    <button class="auth-tab" onclick="authTab('reg')">Реєстрація</button>
  </div>
  <div id="lf">
    <div class="form-group"><label>Email</label><input class="form-input" id="l-em" type="email" placeholder="you@example.com"></div>
    <div class="form-group"><label>Пароль</label><input class="form-input" id="l-pw" type="password" placeholder="••••••••"></div>
    <button class="btn-p" id="l-btn" onclick="doLogin()">Увійти</button>
    <div class="auth-err" id="l-err"></div>
  </div>
  <div id="rf" style="display:none">
    <div class="form-group"><label>Email</label><input class="form-input" id="r-em" type="email" placeholder="you@example.com"></div>
    <div class="form-group"><label>Пароль (мін. 6 символів)</label><input class="form-input" id="r-pw" type="password" placeholder="••••••••"></div>
    <div class="form-group"><label>Нікнейм</label><input class="form-input" id="r-nn" type="text" placeholder="Ваше ім'я"></div>
    <div class="form-group"><label>Юзернейм</label><div class="input-pfx"><span>@</span><input class="form-input" id="r-un" type="text" placeholder="username" autocomplete="off"></div></div>
    <div class="form-group"><label>Аватарка-емодзі</label><div class="emoji-grid" id="reg-ep"></div></div>
    <button class="btn-p" id="r-btn" onclick="doRegister()">Зареєструватись</button>
    <div class="auth-err" id="r-err"></div>
  </div>
</div>
</div>

<div id="app">
<aside class="sidebar" id="sidebar">
  <div class="sb-head">
    <div class="sb-logo">💬</div>
    <div class="sb-title">Sim Chat</div>
  </div>

  <div class="sb-search">
    <input class="srch" id="srch" placeholder="🔍 Пошук чатів, людей, каналів..." oninput="handleSearch(this.value)" autocomplete="off">
    <div class="search-results" id="search-results"></div>
  </div>

  <div class="sb-tabs">
    <button class="stab active" onclick="cTab('all',this)">Всі</button>
    <button class="stab" onclick="cTab('dm',this)">Особисті</button>
    <button class="stab" onclick="cTab('group',this)">Групи</button>
    <button class="stab" onclick="cTab('channel',this)">Канали</button>
  </div>

  <div class="chat-list" id="cl"></div>

  <div class="sb-new">
    <button class="new-cb" onclick="openCreateModal()">+ Нова група / канал</button>
  </div>

  <div class="acc-zone">
    <div class="curr-acc" id="cur-acc" onclick="toggleAccSw()">
      <div class="acc-sw" id="acc-sw"></div>
      <span style="font-size:21px" id="ca-em">👤</span>
      <div style="flex:1;min-width:0">
        <div style="font-size:11px;font-weight:700;color:var(--txt0);white-space:nowrap;overflow:hidden;text-overflow:ellipsis" id="ca-nm">...</div>
        <div style="font-size:10px;color:var(--acc1);font-family:var(--ff-mono)" id="ca-tg">@...</div>
      </div>
      <div class="acc-btns">
        <button class="acc-btn" onclick="event.stopPropagation();openSP()" title="Налаштування">⚙️</button>
        <button class="acc-btn" onclick="event.stopPropagation();doLogout()" title="Вийти">🚪</button>
      </div>
    </div>
  </div>
</aside>

<main class="main" id="main">
  <div id="welcome">
    <div class="w-orb w-orb-1"></div><div class="w-orb w-orb-2"></div>
    <div class="w-cont">
      <div class="w-logo">💬</div>
      <h2>Sim Chat</h2>
      <p>Оберіть чат зліва щоб почати<br>🔒 Всі повідомлення зашифровані E2E</p>
    </div>
  </div>

  <div id="cv" style="display:none;flex-direction:column;height:100%;position:relative">
    <div class="chat-hdr">
      <button class="hamburger" id="hbg" onclick="toggleSb()">☰</button>
      <div class="hdr-av" id="hdr-av" onclick="openChatProfile()">💬</div>
      <div class="hdr-inf">
        <div class="hdr-name" id="hdr-nm">Чат</div>
        <div class="hdr-meta" id="hdr-mt">...</div>
      </div>
      <div class="hdr-acts">
        <button class="hbtn" id="hdr-members-btn" onclick="openChatProfile()" title="Учасники" style="display:none">👥</button>
        <button class="hbtn" onclick="openSP()">⚙️</button>
      </div>
    </div>

    <div class="msgs" id="msgs"></div>

    <div id="rec-ui" class="rec-ui">
      <div class="rec-dot"></div>
      <span class="rec-timer" id="rec-t">0:00</span>
      <span style="flex:1;font-size:10px;color:var(--txt2);font-family:var(--ff-mono)" id="rec-lbl">Запис...</span>
      <button class="rec-cancel" onclick="cancelRec()">Скасувати</button>
      <button class="rec-send" onclick="sendRec()">Надіслати</button>
    </div>

    <div id="iz">
      <div class="inp-area">
        <div class="inp-row">
          <div class="inp-wrap">
            <textarea class="msg-inp" id="mi" placeholder="Повідомлення..." rows="1" onkeydown="miKey(event)" oninput="miResize(this)"></textarea>
            <button class="inp-icon" onclick="startRec(false)" title="Голосове">🎤</button>
            <button class="inp-icon" onclick="startRec(true)" title="Відеокружок">📹</button>
          </div>
          <button class="send-btn" id="sb2" onclick="sendMsg()">➤</button>
        </div>
      </div>
    </div>
    <div id="roz" style="display:none" class="ch-ro">📢 Канал — тільки власник і адміни можуть писати</div>

    <div class="cpp" id="cpp">
      <div class="cpp-head">
        <h3 id="cpp-title">Профіль</h3>
        <button class="cl-btn" onclick="closeCpp()">❌</button>
      </div>
      <div class="cpp-body" id="cpp-body"></div>
    </div>

    <div class="sp" id="sp">
      <div class="sp-head"><h3>⚙️ Налаштування</h3><button class="cl-btn" onclick="closeSP()">❌</button></div>
      <div class="sp-body">
        <div class="ss">
          <div class="ss-title">Профіль</div>
          <div class="av-big" id="sp-av">👤</div>
          <button class="btn-s" onclick="openEmojiModal('avatar')">Змінити аватарку</button>
          <div class="form-group" style="margin-top:9px"><label>Нікнейм</label><input class="form-input" id="sp-nn" placeholder="Нікнейм"></div>
          <button class="btn-s" onclick="saveProfile()">Зберегти профіль</button>
        </div>
        <div class="ss">
          <div class="ss-title">Шрифт повідомлень</div>
          <div class="ss-opt"><span class="ss-lbl">Розмір</span>
            <div class="fsz-btns">
              <button class="fszb" onclick="setFsz('12px',this)">S</button>
              <button class="fszb active" onclick="setFsz('14px',this)">M</button>
              <button class="fszb" onclick="setFsz('16px',this)">L</button>
            </div>
          </div>
          <div class="font-grid" id="font-grid"></div>
        </div>
        <div class="ss">
          <div class="ss-title">Тема / Фон</div>
          <div class="theme-grid" id="theme-grid"></div>
        </div>
        <div class="ss">
          <div class="ss-title">Сповіщення</div>
          <div class="toggle-row" onclick="toggleNotif()">
            <div class="toggle on" id="notif-tgl"></div>
            <span class="ss-lbl">Звуки повідомлень</span>
          </div>
        </div>
        <div class="ss">
          <div class="ss-title">Контакти</div>
          <div class="form-group"><div class="input-pfx"><span>@</span><input class="form-input" id="add-ct" placeholder="username" oninput="searchContactInput(this.value)"></div></div>
          <div id="contact-search-res" style="margin-bottom:6px"></div>
          <div class="ct-list" id="ct-list"></div>
        </div>
        <div class="ss">
          <div class="ss-title">Акаунт</div>
          <button class="btn-d" onclick="doLogout()">🚪 Вийти</button>
        </div>
      </div>
    </div>
  </div>
</main>
